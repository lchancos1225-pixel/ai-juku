# ===== AI =====
AI_CONVERSATION_ENABLED=false

# --- GitHub Models (推奨・無料枠あり) ---
# GitHub の Settings > Developer settings > Personal access tokens で発行
# 必要スコープ: なし (Fine-grained token で Models アクセスを有効化)
GITHUB_TOKEN=

# --- OpenAI 直接 (GPT解約済みなら不要) ---
# OPENAI_API_KEY=

# 使用モデル (GitHub Models で利用可能な例)
#   gpt-4o-mini          : 軽量・低コスト (デフォルト)
#   gpt-4o               : 高性能
#   Phi-4                : Microsoft 製・無料枠大
#   Meta-Llama-3.1-8B-Instruct : OSS・無料枠大
OPENAI_MODEL=gpt-4o-mini

# エンドポイント (GitHub Models デフォルト。OpenAI に戻す場合は下をコメント解除)
OPENAI_BASE_URL=https://models.inference.ai.azure.com/chat/completions
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# ===== セキュリティ =====
# 本番環境では必ず長いランダム文字列を指定してください
# 生成例: python -c "import secrets; print(secrets.token_hex(32))"
AI_SCHOOL_SESSION_SECRET=

# ===== データベース =====
# デフォルトは data/ai_school.db を使用します
# 例: AI_SCHOOL_DB_URL=sqlite:////opt/ai_school/ai_school.db
AI_SCHOOL_DB_URL=

# ===== 初期シード認証情報 (本番環境では必ず上書きしてください) =====
AI_SCHOOL_SEED_OWNER_LOGIN_ID=owner1
AI_SCHOOL_SEED_OWNER_PASSWORD=
AI_SCHOOL_SEED_OWNER_DISPLAY_NAME=JUN
AI_SCHOOL_SEED_CLASSROOM_LOGIN_ID=classroom1
AI_SCHOOL_SEED_CLASSROOM_PASSWORD=
AI_SCHOOL_SEED_CLASSROOM_NAME=サンプル教室
AI_SCHOOL_SEED_TEACHER_LOGIN_ID=teacher1
AI_SCHOOL_SEED_TEACHER_PASSWORD=
AI_SCHOOL_SEED_TEACHER_DISPLAY_NAME=担当講師

# ===== OCR =====
# tesseract の実行パスを変更するときに設定します
AI_SCHOOL_TESSERACT_BIN=tesseract
